# ============================================================
# 生产环境部署配置文件
# ============================================================
# 说明：复制此文件为 .env 并填入实际配置
# ============================================================

# ------------------------------------------------------------
# 高德地图 API (v4 安全版)
# 获取方式：https://lbs.amap.com → 控制台 → 应用管理
# ------------------------------------------------------------
# ① Web 服务 API Key（后端 REST API 地理编码调用）
AMAP_KEY=your_amap_web_service_key

# 安全密钥（jscode，后端调用和高德 v4 验证需要）
AMAP_JSCODE=your_amap_jscode_security_key

# ② Web 端 JS API Key（前端浏览器地图渲染）
AMP_KEY_WEB=your_amap_web_jsapi_key

# ------------------------------------------------------------
# AI 模型配置 (阿里云 DashScope / 通义千问)
# 获取方式：https://dashscope.console.aliyun.com → API Key
# ------------------------------------------------------------
DASHSCOPE_API_KEY=your_dashscope_api_key

# Anthropic 兼容接口基础 URL
ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/apps/anthropic

# 对话模型（轻量级，用于流式对话）
QWEN_MODEL=qwen3.5-plus

# 抽取/故事生成模型（重型，用于复杂任务）
QWEN_MODEL_HEAVY=qwen-max

# ------------------------------------------------------------
# PostgreSQL 数据库配置
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=family_migration
DB_USER=postgres
DB_PASSWORD=your_db_password

# ------------------------------------------------------------
# 服务器端口
# ------------------------------------------------------------
PORT=3005

# ------------------------------------------------------------
# 生产环境特别配置
# ------------------------------------------------------------
# NODE_ENV=production
# LOG_LEVEL=warn
# 启用 HTTPS（如需要）
# HTTPS_ENABLED=false
# HTTPS_CERT_PATH=/path/to/cert.pem
# HTTPS_KEY_PATH=/path/to/key.pem
