// ============================================================
// 故事播放器
// ============================================================
function initStoryPlayer() {
  const player  = document.getElementById('story-player');
  const progress = document.getElementById('story-progress');

  // 生成进度点
  progress.innerHTML = state.chapters
    .map((_, i) => `<div class="progress-dot ${i === 0 ? 'active' : ''}" id="dot-${i}"></div>`)
    .join('');

  player.classList.add('visible');
  state.currentChapter = 0;
  renderChapter(0);
}

function renderChapter(idx) {
  const ch = state.chapters[idx];
  if (!ch) return;

  // 更新进度
  state.chapters.forEach((_, i) => {
    const dot = document.getElementById(`dot-${i}`);
    if (dot) {
      dot.className = 'progress-dot' + (i < idx ? ' done' : i === idx ? ' active' : '');
    }
  });

  // 更新文字
  document.getElementById('chapter-label').textContent =
    `${beatTypeLabel(ch.beat_type)} · ${idx + 1} / ${state.chapters.length}`;
  document.getElementById('chapter-counter').textContent =
    `${idx + 1} / ${state.chapters.length}`;

  const narrationEl = document.getElementById('story-narration');
  narrationEl.style.opacity = '0';
  setTimeout(() => {
    narrationEl.innerHTML = ch.narration.replace(/\n/g, '<br>');
    narrationEl.style.transition = 'opacity 0.6s';
    narrationEl.style.opacity = '1';
  }, 150);

  const histEl = document.getElementById('story-historical');
  if (ch.historical_context) {
    histEl.textContent = ch.historical_context;
    histEl.classList.add('visible');
  } else {
    histEl.classList.remove('visible');
  }

  // 地图聚焦（根据章节类型）
  highlightChapterOnMap(idx);
}

function highlightChapterOnMap(idx) {
  if (!state.mapData?.paths?.[idx]) return;
  const path = state.mapData.paths[idx];
  if (path.to_lng) {
    state.amapInstance?.setZoomAndCenter(7, [path.to_lng, path.to_lat], false, 800);
  }
}

function nextChapter() {
  if (state.currentChapter < state.chapters.length - 1) {
    state.currentChapter++;
    renderChapter(state.currentChapter);
  }
}

function prevChapter() {
  if (state.currentChapter > 0) {
    state.currentChapter--;
    renderChapter(state.currentChapter);
  }
}

function beatTypeLabel(type) {
  const map = {
    anchor: '序 · 时间锚点', person: '第一代 · 出现', danger: '险境',
    meeting: '相遇', choice: '选择', arrival: '抵达', silence: '尾声',
  };
  return map[type] || type;
}

// ============================================================
// 工具函数
// ============================================================
function setLoading(visible, text) {
  const overlay = document.getElementById('loading-overlay');
  if (visible) {
    overlay.classList.add('visible');
    document.getElementById('loading-text').textContent = text;
  } else {
    overlay.classList.remove('visible');
  }
}

function setStep(n) {
  [1, 2, 3].forEach(i => {
    const el = document.getElementById(`step-${i}`);
    el.className = 'step-pill' + (i < n ? ' done' : i === n ? ' active' : '');
  });
}

function updateMapHeader(data) {
  if (!data) return;
  document.getElementById('map-title').textContent =
    `${data.family_name || ''}家族迁徙地图`;
  const years = data.migrations?.map(m => m.year).filter(Boolean);
  if (years?.length) {
    document.getElementById('map-subtitle').textContent =
      `${Math.min(...years)} — 今日 · ${data.migrations.length} 段迁徙`;
  }
}

// 回车发送
document.getElementById('chat-input').addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
});

// 自动高度
document.getElementById('chat-input').addEventListener('input', function () {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 120) + 'px';
});

// ── 初始化 ───────────────────────────────────────────────────
// v4 使用 AMapLoader 异步加载，initMap 内部处理加载失败的降级
window.addEventListener('load', () => {
  initMap();
});

// ============================================================
// Demo 循环动画功能
// ============================================================

// 播放 Demo 动画（循环）
function startDemoAnimation() {
  if (state.isDemoPlaying) return;  // 已经在播放
  state.isDemoPlaying = true;
  console.log('[Demo] 开始循环播放 Demo 动画');

  // 立即播放一次
  playDemoOnce();

  // 每 20 秒循环播放一次
  state.demoAnimationTimer = setInterval(() => {
    if (!state.mapData) {  // 只有在没有用户数据时才播放
      playDemoOnce();
    }
  }, 20000);
}

// 播放一次 Demo 动画
function playDemoOnce() {
  if (!state.amapInstance || state.mapData) return;

  console.log('[Demo] 播放 Demo 动画');

  // 清除旧的标记和路径
  state.markers.forEach(m => m.remove());
  state.polylines.forEach(p => p.remove());
  state.markers = [];
  state.polylines = [];
  document.getElementById('legend-items').innerHTML = '';
  document.getElementById('map-legend').classList.remove('visible');

  // 使用 Demo 数据渲染
  renderMigrationPaths(DEMO_PATHS);

  // 更新标题
  document.getElementById('map-title').textContent = '家族迁徙示例 · 四代足迹';
  document.getElementById('map-subtitle').textContent = '1904 双城 — 今日 北京 · 120 年 · 4 段迁徙';
}

// 停止 Demo 动画
function stopDemoAnimation() {
  if (state.demoAnimationTimer) {
    clearInterval(state.demoAnimationTimer);
    state.demoAnimationTimer = null;
  }
  state.isDemoPlaying = false;
  console.log('[Demo] 停止 Demo 动画');
}
</script>
</body>
</html>
