<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>家族迁徙 · 寻根</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">

<style>
:root{
  --night:#090806;--ink0:#110f0b;--ink1:#1a1710;--ink2:#232018;
  --gold:#c8a96e;--gold2:#e8d098;--cream:#eee8d8;
  --mist:rgba(238,232,216,0.5);--mist2:rgba(238,232,216,0.25);
  --mist3:rgba(238,232,216,0.1);--mist4:rgba(238,232,216,0.05);
  --serif:'Noto Serif SC',serif;--mono:'DM Mono',monospace;--sans:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{width:100%;height:100%;background:var(--night);overflow:hidden;
  color:var(--cream);font-family:var(--sans);-webkit-font-smoothing:antialiased;}

/* 顶部导航栏 */
.nav-bar{
  position:absolute;top:0;left:0;right:0;z-index:100;
  padding:calc(8px + env(safe-area-inset-top)) 16px 8px;
  background:rgba(9,8,6,0.95);backdrop-filter:blur(12px);
  border-bottom:1px solid var(--mist4);
  display:flex;align-items:center;justify-content:space-between;
}
.nav-title{
  font-family:var(--serif);font-size:17px;font-weight:400;
  color:var(--cream);letter-spacing:0.05em;
}
.nav-action{
  font-size:13px;color:var(--gold);text-decoration:none;
  padding:6px 12px;border:1px solid var(--mist4);
  border-radius:16px;background:rgba(200,169,110,0.1);
}

/* 聊天容器 */
.chat-container{
  position:absolute;top:0;left:0;right:0;bottom:0;
  display:flex;flex-direction:column;
  padding-top:calc(50px + env(safe-area-inset-top));
  padding-bottom:calc(80px + env(safe-area-inset-bottom));
}

/* 消息列表 */
.messages{
  flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;
  padding:16px 12px;
  display:flex;flex-direction:column;gap:12px;
}
.messages::-webkit-scrollbar{display:none;}

/* 消息气泡 */
.message{
  max-width:85%;animation:msgIn 0.3s ease;
}
@keyframes msgIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:none;}}

.message.ai{align-self:flex-start;}
.message.user{align-self:flex-end;}

.message.ai .bubble{
  background:var(--ink1);border:1px solid var(--mist4);
  border-radius:16px 16px 16px 4px;
  padding:12px 14px;
}
.message.user .bubble{
  background:var(--gold);color:var(--night);
  border-radius:16px 16px 4px 16px;
  padding:12px 14px;font-weight:500;
}

.message .bubble{
  font-size:15px;line-height:1.6;
}
.message .bubble p{margin-bottom:8px;}
.message .bubble p:last-child{margin-bottom:0;}

/* 引导式问题卡片 */
.guidance-cards{
  padding:0 12px 12px;
  display:flex;flex-direction:column;gap:8px;
}
.guidance-title{
  font-size:12px;color:var(--mist2);
  text-align:center;margin-bottom:4px;
  font-family:var(--mono);
}
.guidance-card{
  background:var(--ink1);border:1px solid var(--mist4);
  border-radius:12px;
  padding:12px 14px;
  cursor:pointer;
  transition:all 0.2s;
}
.guidance-card:active{
  background:var(--ink2);border-color:var(--gold);
}
.guidance-card .gc-question{
  font-size:14px;color:var(--cream);margin-bottom:6px;
  font-family:var(--serif);font-weight:300;
}
.guidance-card .gc-hint{
  font-size:11px;color:var(--mist2);
  line-height:1.5;
}

/* 输入区域 */
.input-area{
  position:absolute;bottom:0;left:0;right:0;
  padding:10px 12px calc(8px + env(safe-area-inset-bottom));
  background:rgba(9,8,6,0.95);backdrop-filter:blur(12px);
  border-top:1px solid var(--mist4);
  display:flex;gap:8px;align-items:flex-end;
}
.input-wrapper{
  flex:1;position:relative;
}
#chat-input{
  width:100%;max-height:100px;
  background:var(--ink1);border:1px solid var(--mist4);
  border-radius:18px;
  padding:10px 14px;
  color:var(--cream);font-size:15px;
  font-family:var(--sans);resize:none;
  outline:none;transition:border-color 0.2s;
}
#chat-input:focus{border-color:var(--gold);}
#chat-input::placeholder{color:var(--mist2);}
.send-btn{
  width:40px;height:40px;border-radius:50%;
  background:var(--gold);border:none;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;flex-shrink:0;
  transition:transform 0.1s;
}
.send-btn:active{transform:scale(0.92);}
.send-btn svg{
  width:18px;height:18px;stroke:var(--night);
  stroke-width:2.5;fill:none;
}

/* 加载状态 */
.typing-indicator{
  display:flex;gap:4px;padding:8px 12px;
}
.typing-dot{
  width:6px;height:6px;border-radius:50%;
  background:var(--mist2);
  animation:typing 1.4s ease-in-out infinite;
}
.typing-dot:nth-child(2){animation-delay:0.2s;}
.typing-dot:nth-child(3){animation-delay:0.4s;}
@keyframes typing{0%,100%{opacity:0.3;transform:scale(0.8);}50%{opacity:1;transform:scale(1.2);}}

/* 快捷操作栏 */
.quick-actions{
  position:fixed;bottom:calc(70px + env(safe-area-inset-bottom));left:0;right:0;
  padding:8px 12px;
  background:rgba(9,8,6,0.95);backdrop-filter:blur(12px);
  border-top:1px solid var(--mist4);
  display:flex;gap:8px;justify-content:center;
  transition:all 0.3s;
  z-index:50;
}
.quick-actions.hidden{
  display:none;
}
.quick-action-btn{
  padding:8px 16px;
  background:rgba(200,169,110,0.15);
  border:1px solid var(--gold);
  border-radius:20px;
  color:var(--gold);font-size:13px;
  cursor:pointer;
  transition:all 0.2s;
  font-family:var(--sans);
}
.quick-action-btn:active{
  background:rgba(200,169,110,0.3);
  transform:scale(0.96);
}
.quick-action-btn.primary{
  background:var(--gold);
  color:var(--night);
  font-weight:500;
}
.quick-action-btn.primary:active{
  background:rgba(200,169,110,0.8);
}

/* 地图预览卡片 */
.map-preview{
  background:var(--ink1);border:1px solid var(--mist4);
  border-radius:12px;padding:12px;
  margin-top:8px;
}
.map-preview-title{
  font-family:var(--serif);font-size:14px;color:var(--cream);
  margin-bottom:6px;
}
.map-preview-btn{
  display:inline-block;
  padding:8px 16px;
  background:rgba(200,169,110,0.15);
  border:1px solid var(--gold);
  border-radius:8px;
  color:var(--gold);font-size:13px;
  text-decoration:none;
}

/* 生成地图按钮条 */
.generate-map-bar{
  padding:0 12px 10px;
  display:none;
}
.generate-map-bar.visible{display:block;}
.generate-map-btn{
  width:100%;
  padding:12px 16px;
  background:linear-gradient(135deg, rgba(200,169,110,0.2) 0%, rgba(200,169,110,0.1) 100%);
  border:1px solid var(--gold);
  border-radius:12px;
  color:var(--gold);
  font-size:14px;
  font-weight:500;
  cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.2s;
}
.generate-map-btn:active{
  background:rgba(200,169,110,0.25);
  transform:scale(0.98);
}
</style>
</head>
<body>

<!-- 顶部导航 -->
<div class="nav-bar">
  <div class="nav-title">寻根</div>
  <div style="display:flex;gap:8px;">
    <a href="#" onclick="resetChat();return false;" class="nav-action" style="font-size:12px;padding:6px 10px;">重新开始</a>
  </div>
</div>

<!-- 聊天容器 -->
<div class="chat-container">
  <!-- 消息列表 -->
  <div class="messages" id="messages">
    <div class="message ai">
      <div class="bubble">
        <p>你好，我来帮你记录你的家族故事。</p>
        <p>先说说你自己吧——<strong>你现在住在哪里？</strong></p>
      </div>
    </div>
  </div>

  <!-- 引导式问题卡片 -->
  <div class="guidance-cards" id="guidance-cards">
    <div class="guidance-title">你可以这样回答</div>
    <div class="guidance-card" onclick="useGuidance(this)" data-text="我住在北京市朝阳区。">
      <div class="gc-question">我住在北京市朝阳区。</div>
      <div class="gc-hint">直接告诉我你现在的居住地</div>
    </div>
    <div class="guidance-card" onclick="useGuidance(this)" data-text="我家在北方，具体是北京。">
      <div class="gc-question">我家在北方，具体是北京。</div>
      <div class="gc-hint">简单描述地理位置</div>
    </div>
    <div class="guidance-card" onclick="useGuidance(this)" data-text="我想先聊聊我父亲的经历。">
      <div class="gc-question">我想先聊聊我父亲的经历。</div>
      <div class="gc-hint">从你想讲的家人开始</div>
    </div>
  </div>

  <!-- 快捷操作栏 -->
  <div class="quick-actions" id="quick-actions">
    <button class="quick-action-btn" id="finish-btn" onclick="userFinish()">我说完了</button>
    <button class="quick-action-btn primary" id="organize-btn" onclick="goToStoryTimeline()" style="display:none;">整理家族故事 →</button>
  </div>

  <!-- 输入区域 -->
  <div class="input-area">
    <div class="input-wrapper">
      <textarea id="chat-input" placeholder="用你自己的方式描述..." rows="1"></textarea>
    </div>
    <button class="send-btn" onclick="sendMessage()">
      <svg viewBox="0 0 24 24">
        <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
      </svg>
    </button>
  </div>
</div>

<script>
const API_BASE = '/amapapi';
const STORAGE_KEY = 'family_migration_chat_state';

// 从 localStorage 加载状态
function loadState() {
  try {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved) {
      const parsed = JSON.parse(saved);
      state.familyId = parsed.familyId || null;
      state.messages = parsed.messages || [];
      state.userFinished = parsed.userFinished || false;
      return parsed;
    }
  } catch (e) {
    console.warn('加载状态失败:', e);
  }
  return null;
}

// 保存状态到 localStorage
function saveState() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({
      familyId: state.familyId,
      messages: state.messages,
      userFinished: state.userFinished,
    }));
  } catch (e) {
    console.warn('保存状态失败:', e);
  }
}

// 清除状态（用户需要时）
function clearState() {
  try {
    localStorage.removeItem(STORAGE_KEY);
  } catch (e) {}
}

const state = {
  messages: [],
  familyId: null,
  userFinished: false,  // 用户是否已点击"我说完了"
  mapData: null,
  isWaiting: false,
};

// 页面加载时恢复状态和聊天记录
const savedState = loadState();
if (savedState && savedState.messages.length > 0) {
  // 清空初始欢迎消息
  document.getElementById('messages').innerHTML = '';
  // 恢复历史消息
  savedState.messages.forEach(msg => {
    addMessage(msg.content, msg.role === 'assistant' ? 'ai' : 'user');
  });
  // 隐藏引导卡片（已有历史对话）
  document.getElementById('guidance-cards').style.display = 'none';
  // 如果用户已结束对话，隐藏"我说完了"按钮，显示操作按钮
  if (savedState.userFinished) {
    const finishBtn = document.getElementById('finish-btn');
    if (finishBtn) finishBtn.style.display = 'none';
    const organizeBtn = document.getElementById('organize-btn');
    if (organizeBtn) {
      organizeBtn.style.display = 'block';
      // 已有数据时，按钮文字改为"查看家族地图"
      if (savedState.familyId) {
        organizeBtn.textContent = '查看家族地图 →';
      }
    }
  }
}

// 自动调整输入框高度
const inputEl = document.getElementById('chat-input');
inputEl.addEventListener('input', function() {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 100) + 'px';
});

// 发送消息
function sendMessage() {
  const text = inputEl.value.trim();
  if (!text) return;

  // 添加用户消息到 UI
  addMessage(text, 'user');
  // 添加到状态
  state.messages.push({ role: 'user', content: text });
  saveState();

  inputEl.value = '';
  inputEl.style.height = 'auto';

  // 隐藏引导卡片
  document.getElementById('guidance-cards').style.display = 'none';

  // 调用 API
  callAPI(text);
}

// 使用引导式问题
function useGuidance(card) {
  const text = card.dataset.text;
  inputEl.value = text;
  sendMessage();
}

// 用户主动结束对话
function userFinish() {
  // 更新状态
  state.userFinished = true;
  saveState();

  // 隐藏"我说完了"按钮
  const finishBtn = document.getElementById('finish-btn');
  if (finishBtn) {
    finishBtn.style.display = 'none';
  }

  // 显示"整理家族故事"按钮
  const organizeBtn = document.getElementById('organize-btn');
  if (organizeBtn) {
    organizeBtn.style.display = 'block';
    // 已有数据时，按钮文字改为"查看家族地图"
    if (state.familyId) {
      organizeBtn.textContent = '查看家族地图 →';
    }
  }

  // 添加系统消息
  const hasData = state.familyId ? '已有家族数据，点击下方按钮直接查看。' : '好的，请点击下方"整理家族故事"按钮生成地图';
  addMessage(`<em style="color:var(--mist2);font-size:13px;">${hasData}</em>`, 'ai');
}

// 添加消息到聊天
function addMessage(text, type) {
  const messagesEl = document.getElementById('messages');
  const msgDiv = document.createElement('div');
  msgDiv.className = `message ${type}`;
  msgDiv.innerHTML = `<div class="bubble">${text}</div>`;
  messagesEl.appendChild(msgDiv);
  messagesEl.scrollTop = messagesEl.scrollHeight;
  return msgDiv;
}

// 显示 AI 输入中
function showTyping() {
  const messagesEl = document.getElementById('messages');
  const typingDiv = document.createElement('div');
  typingDiv.className = 'message ai';
  typingDiv.id = 'typing-indicator';
  typingDiv.innerHTML = `
    <div class="bubble" style="background:transparent;border:none;padding:8px 12px;">
      <div class="typing-indicator">
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
      </div>
    </div>
  `;
  messagesEl.appendChild(typingDiv);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

// 隐藏 AI 输入中
function hideTyping() {
  const typingEl = document.getElementById('typing-indicator');
  if (typingEl) typingEl.remove();
}

// 调用后端 API（SSE 流式响应）
async function callAPI(text) {
  showTyping();

  try {
    // 构建 messages 数组（包含历史消息）
    const messagesPayload = state.messages.map(m => ({
      role: m.role,
      content: m.content,
    }));
    // 添加当前用户消息
    messagesPayload.push({ role: 'user', content: text });

    const response = await fetch(`${API_BASE}/chat`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        messages: messagesPayload,
        familyId: state.familyId,
      }),
    });

    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let aiContent = '';
    let aiDiv = null;

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;

      const lines = decoder.decode(value).split('\n');
      for (const line of lines) {
        if (!line.startsWith('data:')) continue;
        try {
          const data = JSON.parse(line.slice(5));

          if (data.type === 'text') {
            aiContent += data.content;
            hideTyping();
            // 过滤掉 [INFO_COMPLETE] 标记
            const displayContent = aiContent.replace(/\[INFO_COMPLETE\]/g, '');
            if (!aiDiv) {
              // 第一次收到内容，创建消息
              aiDiv = addMessage(displayContent.replace(/\n/g, '<br>'), 'ai');
            } else {
              // 更新已有消息
              aiDiv.querySelector('.bubble').innerHTML = displayContent.replace(/\n/g, '<br>');
            }
            // 滚动到底部
            const messagesEl = document.getElementById('messages');
            messagesEl.scrollTop = messagesEl.scrollHeight;
          }

          if (data.type === 'done') {
            // 将 AI 回复添加到状态（过滤掉 [INFO_COMPLETE] 标记）
            const cleanContent = aiContent.replace(/\[INFO_COMPLETE\]/g, '');
            state.messages.push({ role: 'assistant', content: cleanContent });
            saveState();
          }
        } catch (e) {
          console.warn('SSE 解析失败:', e);
        }
      }
    }

  } catch (e) {
    console.error('API 调用失败:', e);
    hideTyping();
    addMessage('抱歉，连接失败了。请检查网络后重试。', 'ai');
  }
}

// 更新引导卡片
function updateGuidanceCards(questions) {
  const container = document.getElementById('guidance-cards');
  container.style.display = 'flex';

  const title = container.querySelector('.guidance-title');
  title.textContent = '接下来你可以问';

  // 移除旧卡片
  container.querySelectorAll('.guidance-card').forEach(c => c.remove());

  questions.forEach(q => {
    const card = document.createElement('div');
    card.className = 'guidance-card';
    card.onclick = () => useGuidance(card);
    card.dataset.text = q;
    card.innerHTML = `
      <div class="gc-question">${q}</div>
    `;
    container.appendChild(card);
  });
}

// 回车发送（不带 Shift）
inputEl.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
});

// 重置聊天
function resetChat() {
  if (!confirm('确定要清除所有聊天记录并重新开始吗？')) return;
  clearState();
  location.reload();
}

// 跳转到故事时间线
function goToStoryTimeline() {
  if (!state.messages || state.messages.length === 0) {
    alert('请先完成家族故事对话');
    return;
  }

  // 已有 familyId 时，直接使用缓存数据（跳过分析）
  if (state.familyId) {
    loadExistingData(state.familyId);
    return;
  }

  // 首次分析，调用 extract API
  // 显示加载提示
  const btn = document.getElementById('organize-btn');
  if (btn) {
    btn.innerHTML = '正在解析家族数据...';
    btn.disabled = true;
  }
  callExtractAPI();
}

// 加载已有数据（跳过分析）
async function loadExistingData(familyId) {
  console.log('[mobile-chat] 加载已有数据 familyId:', familyId);

  try {
    const response = await fetch(`${API_BASE}/migration-map/${familyId}`);
    const data = await response.json();

    console.log('[mobile-chat] 加载已有数据成功:', data);

    if (!data.success) {
      throw new Error(data.error || '数据加载失败');
    }

    // 保存到 sessionStorage 供 story-timeline 使用
    const pendingData = {
      familyId: familyId,
      data: data,
      rawChatText: '',  // 没有原始聊天内容
    };
    sessionStorage.setItem('pending_chat_data', JSON.stringify(pendingData));

    // 跳转到 story-timeline
    window.location.href = `/story-timeline.html?familyId=${familyId}`;

  } catch (e) {
    console.error('[mobile-chat] 加载已有数据失败:', e);
    alert('加载失败：' + e.message + '\n将重新分析数据');
    // 加载失败，回退到重新分析
    callExtractAPI();
  }
}

// 调用 extract API 解析家族数据
async function callExtractAPI() {
  const conversationText = state.messages
    .map(m => `${m.role === 'user' ? '用户' : 'AI'}: ${m.content}`)
    .join('\n');

  console.log('[mobile-chat] 调用 extract API');
  console.log('[mobile-chat] state.familyId:', state.familyId);
  console.log('[mobile-chat] state.messages 长度:', state.messages?.length);
  console.log('[mobile-chat] conversationText 长度:', conversationText?.length);

  // 检查是否有足够的对话内容
  if (!conversationText || conversationText.length < 20) {
    alert('对话内容太少，请先多聊一些家族故事');
    const btn = document.querySelector('.generate-map-btn');
    if (btn) {
      btn.innerHTML = '整理家族故事 →';
      btn.disabled = false;
    }
    return;
  }

  try {
    const response = await fetch(`${API_BASE}/extract`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ conversationText, familyId: state.familyId }),
    });

    console.log('[mobile-chat] response status:', response.status);
    const extractData = await response.json();
    console.log('[mobile-chat] extract API 返回:', extractData);

    if (!extractData.success) {
      throw new Error(extractData.error || '解析失败');
    }

    // 检查是否有有效的 familyId 返回
    if (!extractData.familyId) {
      throw new Error('API 没有返回 familyId');
    }

    // 保存到 sessionStorage 供 story-timeline 使用
    const pendingData = {
      familyId: extractData.familyId,
      data: extractData.data,
      rawChatText: conversationText,  // 保存原始聊天内容
    };
    sessionStorage.setItem('pending_chat_data', JSON.stringify(pendingData));
    console.log('[mobile-chat] 已保存到 sessionStorage:', pendingData);
    console.log('[mobile-chat] sessionStorage 内容:', sessionStorage.getItem('pending_chat_data'));

    // 更新 state
    state.familyId = extractData.familyId;
    saveState();

    // 跳转到 story-timeline 页面
    const redirectUrl = `/story-timeline.html?familyId=${extractData.familyId}`;
    console.log('[mobile-chat] 跳转到:', redirectUrl);
    window.location.href = redirectUrl;

  } catch (e) {
    console.error('[mobile-chat] 解析失败:', e);
    console.error('[mobile-chat] 错误堆栈:', e.stack);

    // 即使失败也跳转到 story-timeline，但显示错误信息
    const errorMsg = e.message || '解析失败，请重试';
    sessionStorage.setItem('story_timeline_error', JSON.stringify({
      error: errorMsg,
      time: Date.now(),
    }));

    // 如果有临时 familyId 也传递
    if (state.familyId) {
      window.location.href = `/story-timeline.html?familyId=${state.familyId}`;
    } else {
      alert(errorMsg + '\n\n请确保聊天中包含家族故事信息（如家人、地点、时间等）');
      // 恢复按钮
      const btn = document.getElementById('organize-btn');
      if (btn) {
        btn.innerHTML = '整理家族故事 →';
        btn.disabled = false;
      }
    }
  }
}
</script>
</body>
</html>
